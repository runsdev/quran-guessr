{
  "name": "quran-guessr",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint '**/*.{css,scss}'",
    "lint:css:fix": "stylelint '**/*.{css,scss}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run lib/__tests__/qf-sdk-endpoints.test.ts app/quiz/missing-word-count/__tests__/getQuestion.test.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:reset": "tsx prisma/seed.ts --reset",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@next/third-parties": "^16.2.6",
    "@prisma/client": "^6.19.0",
    "@quranjs/api": "^3.2.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.17",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^57.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "prisma": "^6.19.0",
    "sass": "^1.87.0",
    "stylelint": "^16.19.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^6.11.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,mts,json,md}": "prettier --write"
  },
  "browserslist": [
    "chrome >= 93",
    "edge >= 93",
    "safari >= 15.4",
    "firefox >= 90"
  ]
}
