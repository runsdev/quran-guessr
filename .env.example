AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Quran Foundation OAuth2 – https://api-docs.quran.foundation/request-access/
# Server-only (Client Credentials + user token exchange/refresh). Never expose in browser code.
QF_CLIENT_ID=""
QF_CLIENT_SECRET=""
# Exposed to the browser for public SDK OAuth2 helper flows (no secret, read-only identity).
NEXT_PUBLIC_QF_CLIENT_ID=""
# Set to "production" to use oauth2.quran.foundation (default: prelive)
QF_ENVIRONMENT="development"